# ── MongoDB ─────────────────────────────────────────────────
# Get a free cluster at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bakeryDB?retryWrites=true&w=majority

# ── JWT Secret ───────────────────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Frontend URL (for CORS) ──────────────────────────────────
# Add your Netlify/GitHub Pages URL here
FRONTEND_URL=https://your-bakery-frontend.netlify.app
